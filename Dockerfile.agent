FROM golang:1.26-bookworm AS build

WORKDIR /src
COPY go.mod ./
COPY cmd ./cmd
COPY internal ./internal
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /out/jetsonfabric-agent ./cmd/jetsonfabric-agent

FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=build /out/jetsonfabric-agent /jetsonfabric-agent
USER nonroot:nonroot
ENTRYPOINT ["/jetsonfabric-agent"]
