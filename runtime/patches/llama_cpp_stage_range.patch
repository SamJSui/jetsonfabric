+bool llama_context::set_layer_range(uint32_t layer_start, uint32_t layer_end) {
+    const uint32_t n_layer = model.hparams.n_layer();
+    if (layer_start >= layer_end || layer_end > n_layer) {
+        LLAMA_LOG_ERROR("%s: invalid layer range [%u:%u) for %u layers\n",
+                __func__, layer_start, layer_end, n_layer);
+        return false;
+    }
+    if (cparams.layer_start == layer_start && cparams.layer_end == layer_end) {
+        return true;
+    }
+    cparams.layer_start = layer_start;
+    cparams.layer_end   = layer_end;
+    gf_res_prev->reset();
+    sched_need_reserve = true;
+    return true;
+}
+
 void llama_context::set_nextn_layer_offset(int32_t offset) {
     cparams.nextn_layer_offset = offset;
 }
