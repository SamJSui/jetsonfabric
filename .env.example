# JetsonFabric environment template
# Copy this file to a private .env or /etc/jetsonfabric/node.env on each machine.
# Do not commit real node IPs, private hostnames, or join tokens.

# Shared
JOIN_TOKEN=replace-me
MODEL=qwen2.5-coder-1.5b-q4

# Control process
CONTROL_LISTEN=0.0.0.0:52415
BENCHMARKS_PATH=/data/benchmarks.jsonl
MODEL_REGISTRY_PATH=/app/configs/models.example.json

# Worker/node identity
NODE_NAME=dopey
AGENT_LISTEN=0.0.0.0:52416

# Cross-host URLs
# Use TEST-NET placeholder addresses in committed examples.
# Replace these locally with Tailscale, LAN, or DNS addresses reachable from your nodes.
CONTROL_URL=http://192.0.2.10:52415
ADVERTISE_URL=http://192.0.2.20:52416

# Local engine selected by docker-compose profile or local process setup.
ENGINE=jetsonfabric-runtime
ENGINE_URL=http://engine:9090
ENGINE_PORT=9090

# Runtime settings
RUNTIME_MODE=single_node
MODEL_DIR=/var/lib/jetsonfabric/models
PLAN_DIR=/var/lib/jetsonfabric/plans
ASSIGNMENT_PATH=/etc/jetsonfabric/runtime-assignment.json

# llama.cpp hotswap settings
LLAMA_IMAGE=ghcr.io/ggml-org/llama.cpp:server
MODEL_FILE=qwen2.5-coder-1.5b-instruct-q4_k_m.gguf
CTX_SIZE=4096
