# Local JetsonFabric development configuration
# Copy to .env.local and keep that file private.

# Model registered by the Go coordinator and loaded by the supervised runtime.
MODEL=qwen2.5-coder-1.5b-q4
MODEL_PATH=models/qwen.gguf

# Native runtime build. Compute capability 8.7 is correct for Jetson Orin.
# Start with 1 or 2 jobs on an 8 GB Jetson; use 4 if the build is stable.
RUNTIME_BUILD_JOBS=2
RUNTIME_BUILD_DIR=runtime/build
RUNTIME_CUDA_ARCH=87
CUDA_NVCC=/usr/local/cuda/bin/nvcc
RUNTIME_BIN=dist/jetsonfabric-runtime-worker

# Runtime process defaults for direct run-node/run-runtime commands.
RUNTIME_LISTEN=127.0.0.1:0
RUNTIME_ENGINE=llama.cpp
RUNTIME_COMPUTE_BACKEND=cuda
RUNTIME_MODE=pipeline_parallel
RUNTIME_CTX_SIZE=4096
RUNTIME_N_GPU_LAYERS=999
RUNTIME_THREADS=0

# Direct run-node/run-runtime assignment. `make dev-up` reads the GGUF layer
# count and creates stage 0/1 over the complete model automatically.
STAGE_INDEX=0
STAGE_COUNT=1
LAYER_START=0
LAYER_END=28

# Go node defaults.
NODE_NAME=
NODE_CLUSTER_ID=home-lab
NODE_LISTEN=0.0.0.0:0
NODE_ADVERTISE_URL=
NODE_DATA_DIR=
NODE_DISCOVERY=mdns
NODE_RUNTIME_URL=auto
NODE_ROLE=auto
NODE_ENGINE=llama.cpp
NODE_SEEDS=

# Shared coordinator and peer-stage credential. Generate a unique value for any
# persistent cluster; this example value is only suitable for local development.
JETSONFABRIC_CLUSTER_TOKEN=replace-with-a-random-cluster-token

# Local development lifecycle. The normal dev node and supervised runtime use
# fixed ports so a duplicate or stale process fails visibly at bind time.
# The +1 node/runtime pair is reserved for explicit colocated integration tests.
JF_NODE0_PORT=19180
JF_NODE1_PORT=19181
JF_RUNTIME_PORT=19190
JF_RUNTIME1_PORT=19191
JF_DEV_WORK_DIR=.cache/jetsonfabric/dev
DEV_MAX_TOKENS=16
